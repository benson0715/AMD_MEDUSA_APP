	poc_gpio_ints: poc-gpio-ints {
		compatible = "vnd,poc-gpio-ints";

		int_AC_PRSNT: AC_PRSNT_int {
			irq-pin = <&AC_PRSNT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_ac_psrent_callback";
		};
		
		int_PWR_BTN_N: PWR_BTN_N_int {
			irq-pin = <&PWR_BTN_N>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_pwr_button_callback";
		};
		/*
		int_HDR_DOCK_IN: HDR_DOCK_IN_int {
			irq-pin = <&HDR_DOCK_IN>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_dock_in_callback";
		};
		*/
		int_HW_LID_CLOSE: HW_LID_CLOSE_int {
			irq-pin = <&HW_LID_CLOSE>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_lid_close_callback";
		};
		
		int_EC_UDC_UART_INT: EC_UDC_UART_INT_int {
			irq-pin = <&EC_UDC_UART_INT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_uart0_int_callback";
		};		

		int_BAT_PRSNT: BAT_PRSNT_int {
			irq-pin = <&BAT_PRSNT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_bat_in_callback";
		};
		
		int_CHGACOK: CHGACOK_int {
			irq-pin = <&CHGACOK>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_chg_ok_callback";
		};			

		int_PDPRSNT: PDPRSNT_int {
			irq-pin = <&PDPRSNT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_pd_src_callback";
		};
		
		int_CHG_EC_PROCHOT: CHG_EC_PROCHOT_int {
			irq-pin = <&CHG_EC_PROCHOT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_chg_prochot_callback";
		};					

		int_APUPWROK: APUPWROK_int {
			irq-pin = <&APUPWROK>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_apu_pwrok_callback";
		};			

		int_APU_THERMTRIP: APU_THERMTRIP_int {
			irq-pin = <&APU_THERMTRIP>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_apu_thermal_trip_callback";
		};
		
		int_APU_EC_ALERT: APU_EC_ALERT_int {
			irq-pin = <&APU_EC_ALERT>;
			flags = <GPIO_INT_EDGE_BOTH>;
			handler = "board_periph_apu_alert_callback";
		};			

		int_SLP_S3_S0A3: SLP_S3_S0A3_int {
