		tbt_m_reset: pout_tbt_m_reset {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_OUTPUT_HIGH | GPIO_UNDEFINE_PIN)>;
			enum-name = "POutTbtMReset";
		};
		sleep_sus: pin_sleep_sus {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_INPUT | GPIO_VWIRE)>;
			enum-name = "PInSleepSus";
		};
		msata_dtct3: pin_msata_dtct3 {
			gpios = <&gpioo 1 (GPIO_ACTIVE_LOW | GPIO_INPUT)>;
			enum-name = "PInMSataDtct3";
		};
		clk_req_gba: pin_clk_req_gba {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
