		};
		bay_not_attach: pin_bay_not_attach {
			gpios = <&gpioa 0 (GPIO_ACTIVE_HIGH | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
			enum-name = "PD0_EC_USBC_INT_N";
		};
		dcin_vbus_en: pout_dcin_vbus_en {
