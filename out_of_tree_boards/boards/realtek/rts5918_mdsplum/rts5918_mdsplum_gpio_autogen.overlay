 * Copyright (c) 2026 Realtek Semiconductor Corporation, SIBG-SD7
 *
 * TODO(realtek-schematic): THIS FILE IS A BISON-LEGACY COPY.
 *
 * Every `gpios = <&gpio<bank> <pin> ...>` entry below was generated
 * from the Lenovo Bison schematic. The pad numbers are NOT correct
 * for AMD MDS Plum yet — they will need to be regenerated from a
 * Plum-specific BGA→net→pin spreadsheet once available.
 *
 * Until then the build still compiles because gpioa..gpiop are all
 * marked `status = "okay"`, but any runtime gpio_pin_set call against
 * an EC_GPIO_xx token will toggle the wrong physical pin. Do not
 * power up real Plum hardware with this overlay verbatim.
 *
 * Regeneration recipe (once Plum_pindef.xlsx exists):
 *   1. Copy boards/nuvoton/npcx4mnx_mdsplum/Plum_main.csv to
 *      gpio/plum_gpio.xlsx with columns: BGA, Net, RTS5918_Function.
 *   2. Run: python scripts/gen_poc_from_xlsx.py
 *      (port from lenovo_p/ecfw-zephyr/scripts/gen_poc_from_xlsx.py)
 *   3. Overwrite this file with the output.
 *
 * AUTO-GENERATED by scripts/gen_poc_from_xlsx.py from:
 *   ../gpio/GPIO_copy.dtsi   -- template: structure, order, labels, comments
 *   ../gpio/bison_gpio.xlsx  -- data: BGA_NET_CODE + rts5918_pin_function
 *                               joined on BGA -> (Code, Net, Function)
 *
 * Transformations applied vs. the source dtsi:
 *   * compatible renamed to the Realtek "vnd,poc-gpios" /
 *     "vnd,poc-gpio-ints" bindings.
 *   * &{/def-io-conf-list} pinmux block removed -- Realtek uses
 *     realtek/ec/rts5918-pinctrl.dtsi, wired up in rts5918_bison.dts.
 *   * eSPI VWire children rewritten: the Nuvoton-specific &msvw0x /
 *     &smvw0x phandles are replaced with &gpioa 0 because RTS5918 has
 *     no msvw/smvw devicetree nodes, but the GPIO_VWIRE flag is kept
 *     so the encoded enum value carries BIT(20) and IoPort.c (line
 *     ~441/584) routes IoSet/IoClr/IoGet calls via the eSPI VW
 *     dispatcher. Each entry in the xlsx `vwire_signals` sheet that
 *     the template doesn't already include is appended automatically.
 *   * `gpios = <&gpio<N> <pin> ...>` rewritten to
 *     `gpios = <&gpio<a..t> <pin%8> ...>` using linear GPIO# =
 *     bank*8+pin (verified from RTS5918.h IRQ comments).
 *   * Nuvoton flag tokens (GPIO_OUTPUT_HIGH / GPIO_OUTPUT_LOW /
 *     GPIO_DEFINE) preserved verbatim -- all are defined in
 *     include/dt-bindings/gpio_defines.h and expand to the expected
 *     bit pattern after the devicetree preprocessor runs.
 *   * GPIO_DEFINE stripped only when that row is falling through to a
 *     GPIO_UNDEFINE_PIN stub (the two are opposites).
 *   * Interrupt children with GPIO_INT_DISABLE flags dropped
 *     (Realtek binding does not accept the disabled variant).
 *   * Template rows without a real BGA mapping that are not eSPI
 *     vwire signals are emitted as GPIO_UNDEFINE_PIN stubs (encoded
 *     enum carries BIT(30) so middle/gpio/mdl_gpio_hub.c safety net
 *     returns -ENODEV at runtime). The PInGpio<NNN> generic-name family
 *     (PInGpio001 / PInGpio0H4 / PInGpioSBY01...) is the lone
 *     exception: it is dropped entirely; syspower.c
 *     IoPortToBeUnpoweredInMOff[] drops these entries so source links.
 *   * A source-grep backfill walks Jupiter / middle / include / app /
 *     common / drivers for any PIn-prefixed or POut-prefixed identifier
 *     referenced but not present in the dtsi template, and emits them
 *     as GPIO_UNDEFINE_PIN stubs too (still excluding PInGpio<NNN>).
 *
 * Do not hand-edit; regenerate with:
 *     python scripts/gen_poc_from_xlsx.py
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/gpio/realtek-gpio.h>
#include <dt-bindings/gpio_defines.h>

&gpioa { status = "okay"; };
&gpiob { status = "okay"; };
&gpioc { status = "okay"; };
&gpiod { status = "okay"; };
&gpioe { status = "okay"; };
&gpiof { status = "okay"; };
&gpiog { status = "okay"; };
&gpioh { status = "okay"; };
&gpioi { status = "okay"; };
&gpioj { status = "okay"; };
&gpiok { status = "okay"; };
&gpiol { status = "okay"; };
&gpiom { status = "okay"; };
&gpion { status = "okay"; };
&gpioo { status = "okay"; };
&gpiop { status = "okay"; };
&gpioq { status = "okay"; };
&gpior { status = "okay"; };
&gpios { status = "okay"; };
&gpiot { status = "okay"; };

/ {
	poc_gpios: poc-gpios {
		compatible = "vnd,poc-gpios";

		// it have to be declared most front if the pin is not used.
		// GPIO091
		EVAL_BOMACO_EN: pout_EVAL_BOMACO_EN {
			gpios = <&gpiol 3 (GPIO_ACTIVE_HIGH | GPIO_INPUT | GPIO_DEFINE)>;
			enum-name = "EC_EVAL_BOMACO_EN";
		};
		// GPIO088
		SLT_PWREN: pout_SLT_PWREN {
