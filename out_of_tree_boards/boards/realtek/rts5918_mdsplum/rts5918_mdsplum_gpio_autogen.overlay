		dock_pwr_dtct: pin_dock_pwr_dtct {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
			enum-name = "PInDockPwrDtct";
		};
		bat_temp2: pin_bat_temp2 {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
			enum-name = "PInBatTemp2";
		};
		fan_id2: pin_fan_id2 {
			gpios = <&gpioa 0 (GPIO_ACTIVE_HIGH | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
