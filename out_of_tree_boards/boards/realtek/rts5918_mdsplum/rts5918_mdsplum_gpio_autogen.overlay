		poa_enable: pout_poa_enable {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_OUTPUT_HIGH | GPIO_UNDEFINE_PIN)>;
			enum-name = "APU_THERMTRIP_N";
		};
		w_wan_on: pout_w_wan_on {
			gpios = <&expander2_p1 4 (GPIO_ACTIVE_HIGH | GPIO_OUTPUT_HIGH | GPIO_EXPANDER)>;
			enum-name = "APU_EC_ALERT_N";
		};
		boost_mode_indicator: pin_boost_mode_indicator {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_INPUT | GPIO_UNDEFINE_PIN)>;
			enum-name = "SLP_S3_S0A3_N";
		};
		video_therm_alert: pout_video_therm_alert {
			gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_OUTPUT_HIGH | GPIO_UNDEFINE_PIN)>;
