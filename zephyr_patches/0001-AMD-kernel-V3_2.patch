+#ifdef CONFIG_ENABLE_ESPI_LTR
+static void espi_npcx_pm_ltr_prepare_tx_header(const struct device *dev,
+	uint8_t rq,  uint8_t latency_scale, uint16_t latency_value)
+{
+	struct espi_reg *const inst = HAL_INSTANCE(dev);
+
+	/*
+	* First 4 bytes of peripheral message cycle command header in tx buffer
+	*
+	* [24:31] - LEN[0:7]     Data length of BM read request package
+	* [20:23] - TAG          Tag of BM read
+	* [16:19] - LEN[8:11]    Data length of BM read request package
+	* [8:15]  - CYCLE_TYPE   Cycle type
+	* [0:7]   - Message code  Note that the Message Code byte in the PBMTXBUFn registers is located at a different position than in the eSPI transaction.
+	*/
+	inst->PBMTXBUF[0] = (ESPI_BM_PM_MESSAGE_LTR & 0xFF)
+	                	| ((ESPI_BM_PM_CYCLE_TYPE & 0xFF) << 8);
+
+	/*
+	* Following 4 bytes of peripheral message LTR in tx buffer
+	* [31:16] - Reserved
+	* [15:8] - Latancy value[7:0]
+	* [7]    - Requirement (0: disable, 1: enable)
+	* [6:5]  - RSVD
+	* [4:2]  - Latency scale[2:0]
+	* [1:0]  - Latancy value[9:8]
+	*/
+	inst->PBMTXBUF[1] =  (((latency_value >> 8) & 0x03) << 0)
+						| ((latency_scale & 0x07) << 2)
+						| ((rq & 0x01) << 7)
+						| ((latency_value & 0xFF) << 8);
+}
+
+static int espi_npcx_send_ltr(const struct device *dev, struct ltr_cfg_pkt *req)
+{
+	struct espi_reg *const inst = HAL_INSTANCE(dev);
+
+	/* Check BM enabled? */
+	if (!IS_BIT_SET(inst->PERCFG, NPCX_PERCFG_BMMEN)) {
+		LOG_ERR("bus master disabled");
+		return -EACCES;
+	}
+
+	/* Check BM Transmit Queue is empty? */
+	if (IS_BIT_SET(inst->PERCTL, NPCX_PERCTL_BM_MSG_AVAIL)) {
+		LOG_ERR("bus master is busy");
+		return -EBUSY;
+	}
+
+	if (req->ltr_req) {
+		espi_npcx_pm_ltr_prepare_tx_header(dev, req->ltr_req, req->ltr_scale, req->latency);
+	} else {
+		espi_npcx_pm_ltr_prepare_tx_header(dev, 0, 0, 0);
+	}
+	SET_FIELD(inst->PERCTL, NPCX_PERCTL_BMPKT_LEN, 8);
+
+	/* Set the PERCTL.NPCX_PERCTL_BM_MSG_AVAIL bit to 1 to enqueue the packet */
+	inst->PERCTL |= BIT(NPCX_PERCTL_BM_MSG_AVAIL);
+
+	int timeout = 100;
+	do {
+		if (IS_BIT_SET(inst->ESPISTS, NPCX_ESPISTS_BMTXDONE))
+			break;
+		// k_msleep(1);
+		k_busy_wait(1000);
+	} while (--timeout);
+
+	if (timeout > 0) {
+		/* Parse completion package in rx buffer */
+		return 0;
 	} else {
 		return -ETIMEDOUT;
 	}
 }
+#endif
 
