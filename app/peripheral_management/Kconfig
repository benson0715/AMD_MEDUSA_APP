config PERIPHERAL_LOG_LEVEL
	int "Peripheral log level"
	depends on PERIPHERAL_MANAGEMENT
	depends on LOG
	default 2 if EC_DEBUG_LOG
	default 0
	help
	  Set log level for peripheral module.
