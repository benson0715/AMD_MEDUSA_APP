config PERIPHERAL_MANAGEMENT
	bool "Enable EC human interface"
	default y
	help
	  Enable EC support for button, switches, this includes:
	  1) Buttons: i.e power button
	  2) Switches: EC HW straps used to change EC behavior.

config PERIPHERAL_BTN_DEBOUNCE_TIME
	int "Switches/button debounce time"
	default 10
	depends on PERIPHERAL_MANAGEMENT
	help
	  Indicate time in milliseconds used to debounce buttons
	  and switches for user interaction.

config PERIPHERAL_AC_PRENT_DEBOUNCE_TIME
	int "AC adapter present debounce time"
	default 10
	depends on PERIPHERAL_MANAGEMENT
	help
	  Indicate time in milliseconds used to debounce AC adapter present.
	  
config PERIPHERAL_UART_DONGLE_DEBOUNCE_TIME
	int "Uart dongle present debounce time"
	default 100
	depends on PERIPHERAL_MANAGEMENT
	help
	  Indicate time in milliseconds used to debounce Uart dongle present.
	  
config PERIPHERAL_BAT_INT_DEBOUNCE_TIME
	int "Bat in debounce time"
	default 10
	depends on PERIPHERAL_MANAGEMENT
	help
	  Indicate time in milliseconds used to debounce Bat in.

config PERIPHERAL_CHG_OK_DEBOUNCE_TIME
	int "chg ok debounce time"
