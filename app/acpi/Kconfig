#EC app acpi build options

# Copyright (C) 2023 Advanced Micro Devices, Inc. All rights reserved.
menu "ACPI"

config EC_ACPI
	bool "Enable ACPI"
	default y
	help
	  Indicate if EC supports ACPI.

config ACPI
	bool "Enable ACPI"
	default y
	help
	  Indicate if EC supports ACPI.
	  
config ACPI_DAC_PWR
	bool "Enable ACPI DAC Power"
	default y
	help
	  Indicate if EC supports ACPI DAC Power adjust.
	  

config ACPI_LOG_LEVEL
	int "ACPI log level"
	depends on EC_ACPI
	depends on LOG
	default 2 if EC_DEBUG_LOG
	default 0
	help
	  Set log level for ACPI module.

endmenu
