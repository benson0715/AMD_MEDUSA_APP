# EC S0S test build options

# Copyright (C) 2023 Advanced Micro Devices, Inc. All rights reserved.
menu "S0S_TEST"

config S0S_TEST
	bool "Enable S0S Testing"
	default y
	help
	  Indicate if EC supports S0S testing

config S0S_TEST_LOG_LEVEL
	int "S0S Test log level"
	depends on S0S_TEST
	depends on LOG
	default 4 if EC_DEBUG_LOG
	default 0
	help
	  Set log level for S0S test module.

endmenu
