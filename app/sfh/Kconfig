# EC SFH module build options

# Copyright (C) 2023 Advanced Micro Devices, Inc. All rights reserved.

config SFH
	bool "Enable sfh feature"
	default n
	help
	  Indicate if udc management sfh is enabled.

config SFH_LOG_LEVEL
	int "sfh log level"
	depends on SFH
	depends on LOG
	default 2 if EC_DEBUG_LOG
	default 0
	help
	  Set log level for sfh.

config SFH_WAIE_LOG_LEVEL
	int "sfh log level"
	depends on SFH
	depends on LOG
	default 2 if EC_DEBUG_LOG
	default 0
	help
	  Set log level for sfh.

